# Supabase接続情報（プロジェクト作成後に実値を埋める）
# このファイルは .env.example。実値は .env に書き、.env は .gitignore で管理する。

# Supabase Personal Access Token (https://supabase.com/dashboard/account/tokens で発行)
# プロジェクト作成・マイグレーション実行時にのみ使用。実行後 revoke 推奨。
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx

# プロジェクト識別情報（npx supabase projects create の結果を反映）
SUPABASE_ORG_ID=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# クライアント接続情報（npx supabase projects api-keys で取得）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# GAS bridge 用（Apps Script から Supabase REST に書き込む際に Apps Script Properties に保存）
# GAS_BRIDGE_API_KEY: 児童アプリ→GAS の認証用（ランダム32文字）
GAS_BRIDGE_API_KEY=
